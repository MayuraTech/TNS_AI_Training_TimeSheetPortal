{
  "family": "tms-application-qa-api",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "executionRoleArn": "arn:aws:iam::119346096827:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::119346096827:role/ecsTaskRole",
  "containerDefinitions": [
    {
      "name": "tms-api",
      "image": "119346096827.dkr.ecr.us-west-2.amazonaws.com/tms-application-qa-api:latest",
      "portMappings": [
        {
          "containerPort": 8080,
          "protocol": "tcp"
        }
      ],
      "essential": true,
      "environment": [
        { "name": "SPRING_PROFILES_ACTIVE", "value": "prod" }
      ],
      "secrets": [
        { "name": "DB_URL",        "valueFrom": "arn:aws:secretsmanager:us-west-2:119346096827:secret:tms/db-url" },
        { "name": "DB_USERNAME",   "valueFrom": "arn:aws:secretsmanager:us-west-2:119346096827:secret:tms/db-username" },
        { "name": "DB_PASSWORD",   "valueFrom": "arn:aws:secretsmanager:us-west-2:119346096827:secret:tms/db-password" },
        { "name": "JWT_SECRET",    "valueFrom": "arn:aws:secretsmanager:us-west-2:119346096827:secret:tms/jwt-secret" },
        { "name": "MAIL_USERNAME", "valueFrom": "arn:aws:secretsmanager:us-west-2:119346096827:secret:tms/mail-username" },
        { "name": "MAIL_PASSWORD", "valueFrom": "arn:aws:secretsmanager:us-west-2:119346096827:secret:tms/mail-password" }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/tms-application-qa-api",
          "awslogs-region": "us-west-2",
          "awslogs-stream-prefix": "ecs"
        }
      },
      "healthCheck": {
        "command": ["CMD-SHELL", "wget -qO- http://localhost:8080/actuator/health || exit 1"],
        "interval": 30,
        "timeout": 10,
        "retries": 3,
        "startPeriod": 60
      }
    }
  ]
}
